<Window x:Class="ElBruno.PresenterTimer.Views.MiniOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ElBruno.PresenterTimer.ViewModels"
        Title="Session Mini Overlay"
        WindowStyle="None"
        Topmost="True"
        ShowInTaskbar="False"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Width="320"
        Height="400"
        Opacity="{Binding OverlayOpacity}">

    <Window.Resources>
        <!-- Pulse animation: double white-flash on the PulseFlash overlay rectangle -->
        <Storyboard x:Key="PulseStoryboard" AutoReverse="False">
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PulseFlash"
                                           Storyboard.TargetProperty="Opacity">
                <LinearDoubleKeyFrame KeyTime="0:0:0.00" Value="0.38"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.15" Value="0.08"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.28" Value="0.28"/>
                <LinearDoubleKeyFrame KeyTime="0:0:0.50" Value="0.00"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>
    </Window.Resources>

    <!-- Root Grid lets PulseFlash overlay float over the entire RootBorder -->
    <Grid>

        <!-- ── Outer draggable shell with border for resize grip ──────────────── -->
        <Border x:Name="RootBorder"
                Background="#D01E1E2E"
                CornerRadius="8"
                Padding="12"
                MouseLeftButtonDown="OnMouseLeftButtonDown"
                BorderBrush="#333"
                BorderThickness="1">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── Header with Close Button ────────────────────────────────── -->
                <Grid Grid.Row="0" Height="24" Margin="0,0,0,8">
                    <TextBlock Text="Session" 
                               FontFamily="Segoe UI" FontSize="12" FontWeight="SemiBold"
                               Foreground="#BBB"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Left"/>
                    <Button x:Name="CloseButton"
                            Click="OnCloseButtonClick"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Width="20" Height="20"
                            Padding="0"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#AAA"
                            FontFamily="Segoe UI" FontSize="14" FontWeight="Bold"
                            Content="✕"
                            ToolTip="Hide overlay">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FF5555"/>
                                        <Setter Property="Background" Value="#33FF5555"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- ── Section Name (Large, Prominent) - Responsive Font Size ──── -->
                <TextBlock x:Name="SectionTitleBlock"
                           Grid.Row="1"
                           Text="{Binding CurrentSectionTitle}"
                           FontFamily="Segoe UI" FontSize="20" FontWeight="Bold"
                           Foreground="#64B5F6"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Top"
                           TextAlignment="Center"
                           TextTrimming="WordEllipsis"
                           Margin="0,0,0,8"
                           AutomationProperties.Name="{Binding CurrentSectionTitle, StringFormat='Current section: {0}'}"
                           AutomationProperties.LiveSetting="Polite"/>

                <!-- ── Time and Controls Panel ────────────────────────────────── -->
                <Grid Grid.Row="2" VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Section Remaining Time -->
                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <TextBlock x:Name="SectionLabelBlock"
                                   Text="Section Remaining" 
                                   FontFamily="Segoe UI" FontSize="11"
                                   Foreground="#FFF"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,4"/>
                        <TextBlock x:Name="SectionTimeBlock"
                                   Text="{Binding CurrentSectionRemainingDisplay}"
                                   FontFamily="Segoe UI Mono,Consolas" FontSize="18" FontWeight="SemiBold"
                                   Foreground="#64B5F6"
                                   HorizontalAlignment="Center"
                                   AutomationProperties.Name="{Binding CurrentSectionRemainingDisplay, StringFormat='Section remaining: {0}'}"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>

                    <!-- Session Lapsed / Remaining Time -->
                    <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Lapsed Label and Value -->
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Lapsed" 
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#FFF"
                                   HorizontalAlignment="Right"
                                   Margin="0,0,8,3"/>
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   x:Name="SessionLapsedBlock"
                                   Text="{Binding SessionLapsedDisplay}"
                                   FontFamily="Segoe UI Mono,Consolas" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#90CAF9"
                                   HorizontalAlignment="Right"
                                   AutomationProperties.Name="{Binding SessionLapsedDisplay, StringFormat='Session lapsed: {0}'}"
                                   AutomationProperties.LiveSetting="Polite"/>

                        <!-- Remaining Label and Value -->
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="Remaining" 
                                   FontFamily="Segoe UI" FontSize="10"
                                   Foreground="#FFF"
                                   HorizontalAlignment="Left"
                                   Margin="8,0,0,3"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding SessionRemainingDisplay}"
                                   FontFamily="Segoe UI Mono,Consolas" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#A5D6A7"
                                   HorizontalAlignment="Left"
                                   AutomationProperties.Name="{Binding SessionRemainingDisplay, StringFormat='Session remaining: {0}'}"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </Grid>

                    <!-- Control Buttons (Pause/Resume, Restart) -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <!-- Pause/Resume Button -->
                        <Button x:Name="PauseResumeButton"
                                Click="OnPauseResumeButtonClick"
                                Width="36" Height="36"
                                Padding="0"
                                Margin="0,0,4,0"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="#555"
                                Foreground="#AAA"
                                FontFamily="Segoe UI" FontSize="16"
                                ToolTip="Pause/Resume">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Content" Value="⏸"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPaused}" Value="True">
                                            <Setter Property="Content" Value="▶"/>
                                            <Setter Property="ToolTip" Value="Resume"/>
                                        </DataTrigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#FFF"/>
                                            <Setter Property="BorderBrush" Value="#777"/>
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Restart Section Button -->
                        <Button x:Name="RestartButton"
                                Click="OnRestartButtonClick"
                                Width="36" Height="36"
                                Padding="0"
                                Margin="4,0,0,0"
                                Background="Transparent"
                                BorderThickness="1"
                                BorderBrush="#555"
                                Foreground="#AAA"
                                FontFamily="Segoe UI" FontSize="16"
                                Content="⟲"
                                ToolTip="Restart section">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Foreground" Value="#FFF"/>
                                            <Setter Property="BorderBrush" Value="#777"/>
                                            <Setter Property="Background" Value="#1A1A1A"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Next Sections List (Scrollable) -->
                    <ScrollViewer Grid.Row="3" 
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,0,0,8">
                        <ItemsControl x:Name="NextSectionsControl" ItemsSource="{Binding NextSections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0A0A0A" 
                                            CornerRadius="3"
                                            BorderBrush="#444"
                                            BorderThickness="1"
                                            Padding="6"
                                            Margin="0,0,0,4">
                                        <TextBlock Text="{Binding Title}"
                                                   FontFamily="Segoe UI" FontSize="9"
                                                   Foreground="#AAA"
                                                   TextTrimming="WordEllipsis"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>

                <!-- ── Mini Progress Bar at Bottom ────────────────────────────── -->
                <Border Grid.Row="3"
                        Background="#1A1A1A"
                        CornerRadius="2"
                        Height="6"
                        Margin="0,0,0,8"
                        BorderBrush="#444"
                        BorderThickness="1">

                    <!-- Progress Fill -->
                    <Grid Background="Transparent">
                        <Rectangle x:Name="ProgressFill"
                                   Fill="#64B5F6"
                                   HorizontalAlignment="Left"
                                   IsHitTestVisible="False"/>
                    </Grid>
                </Border>

                <!-- Empty row 4 for spacing -->
            </Grid>
        </Border>

        <!-- ── Pulse Flash Overlay ────────────────────────────────────────────── -->
        <Rectangle x:Name="PulseFlash"
                   Fill="White"
                   Opacity="0"
                   IsHitTestVisible="False"/>

    </Grid>

</Window>
