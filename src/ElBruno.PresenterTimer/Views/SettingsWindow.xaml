<Window x:Class="ElBruno.PresenterTimer.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ElBruno.PresenterTimer.ViewModels"
        Title="Settings — Session Timeline Overlay"
        Width="680" Height="600"
        MinWidth="560" MinHeight="500"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Tab Control ──────────────────────────────────────────────────── -->
        <TabControl Grid.Row="0" Margin="12,12,12,0">

            <!-- ── GENERAL ──────────────────────────────────────────────────── -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,12">

                        <TextBlock Text="Startup" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Launch app minimized to tray"
                                  IsChecked="{Binding LaunchMinimizedToTray}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Auto-load last session on startup"
                                  IsChecked="{Binding AutoLoadLastSessionOnStartup}"
                                  Margin="0,0,0,6"/>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Session Files" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Remember last session path"
                                  IsChecked="{Binding RememberLastSession}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Show session preview after import"
                                  IsChecked="{Binding ShowSessionPreviewAfterImport}"
                                  Margin="0,0,0,6"/>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Confirmations" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Confirm before resetting a session"
                                  IsChecked="{Binding ConfirmBeforeReset}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Confirm before exiting while a session is running"
                                  IsChecked="{Binding ConfirmBeforeExitWhileRunning}"
                                  Margin="0,0,0,6"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── BEHAVIOR ─────────────────────────────────────────────────── -->
            <TabItem Header="Behavior">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,12">

                        <TextBlock Text="Overlay" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Show timeline overlay when session starts"
                                  IsChecked="{Binding ShowOverlayWhenSessionStarts}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Hide overlay when session ends"
                                  IsChecked="{Binding HideOverlayWhenSessionEnds}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Enable overlay click-through"
                                  IsChecked="{Binding EnableOverlayClickThrough}"
                                  Margin="0,0,0,6"/>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Timer" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Auto-advance sections at section end (always enabled)"
                                  IsChecked="True"
                                  IsEnabled="False"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Keep counting overtime after section end"
                                  IsChecked="{Binding KeepCountingOvertimeAfterSectionEnd}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Keep counting overtime after session end"
                                  IsChecked="{Binding KeepCountingOvertimeAfterSessionEnd}"
                                  Margin="0,0,0,6"/>
                        <CheckBox Content="Pause timer when computer locks"
                                  IsChecked="{Binding PauseTimerWhenComputerLocks}"
                                  Margin="0,0,0,6"/>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Hotkeys" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Enable global hotkeys"
                                  IsChecked="{Binding EnableGlobalHotkeys}"
                                  Margin="0,0,0,6"/>
                        <TextBlock Text="(Configure individual hotkeys in the Hotkeys tab)"
                                   Foreground="Gray" FontSize="11" Margin="20,0,0,0"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── OVERLAY STYLE ────────────────────────────────────────────── -->
            <TabItem Header="Overlay Style">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,12">

                        <!-- Theme + Font -->
                        <TextBlock Text="Theme &amp; Font" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Theme:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.ThemeOptions}}"
                                      SelectedItem="{Binding Theme}" MaxWidth="220" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Font family:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.FontFamilyOptions}}"
                                      SelectedItem="{Binding FontFamily}" MaxWidth="220" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Font size:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="4" Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.FontSizeOptions}}"
                                      SelectedItem="{Binding FontSize}" MaxWidth="220" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Border radius:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="6" Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.BorderRadiusOptions}}"
                                      SelectedItem="{Binding BorderRadius}" MaxWidth="220" HorizontalAlignment="Left"/>
                        </Grid>

                        <Separator Margin="0,8,0,10"/>

                        <!-- Colors -->
                        <TextBlock Text="Colors (hex, e.g. #0078D4)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="6"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Accent color:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Warning color:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding WarningColor, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Overtime color:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding OvertimeColor, UpdateSourceTrigger=PropertyChanged}"/>
                        </Grid>

                        <Separator Margin="0,8,0,10"/>

                        <!-- Opacity sliders -->
                        <TextBlock Text="Opacity (0–100%)" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>

                        <StackPanel Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Overlay opacity:" Width="200" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding OverlayOpacity}" Width="36" VerticalAlignment="Center" Foreground="#0078D4" FontWeight="Bold"/>
                                <TextBlock Text="%" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider Minimum="10" Maximum="100" Value="{Binding OverlayOpacity}"
                                    Width="380" HorizontalAlignment="Left" Margin="0,2,0,0"
                                    IsSnapToTickEnabled="True" TickFrequency="5"
                                    AutomationProperties.Name="Overlay opacity"
                                    AutomationProperties.HelpText="Set overall overlay transparency from 10 to 100 percent"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Current section opacity:" Width="200" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentSectionOpacity}" Width="36" VerticalAlignment="Center" Foreground="#0078D4" FontWeight="Bold"/>
                                <TextBlock Text="%" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider Minimum="0" Maximum="100" Value="{Binding CurrentSectionOpacity}"
                                    Width="380" HorizontalAlignment="Left" Margin="0,2,0,0"
                                    IsSnapToTickEnabled="True" TickFrequency="5"
                                    AutomationProperties.Name="Current section opacity"
                                    AutomationProperties.HelpText="Set opacity for the active section highlight"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Progress fill opacity:" Width="200" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ProgressFillOpacity}" Width="36" VerticalAlignment="Center" Foreground="#0078D4" FontWeight="Bold"/>
                                <TextBlock Text="%" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider Minimum="0" Maximum="100" Value="{Binding ProgressFillOpacity}"
                                    Width="380" HorizontalAlignment="Left" Margin="0,2,0,0"
                                    IsSnapToTickEnabled="True" TickFrequency="5"
                                    AutomationProperties.Name="Progress fill opacity"
                                    AutomationProperties.HelpText="Set opacity for section elapsed progress fill"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Upcoming section opacity:" Width="200" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding UpcomingSectionOpacity}" Width="36" VerticalAlignment="Center" Foreground="#0078D4" FontWeight="Bold"/>
                                <TextBlock Text="%" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider Minimum="0" Maximum="100" Value="{Binding UpcomingSectionOpacity}"
                                    Width="380" HorizontalAlignment="Left" Margin="0,2,0,0"
                                    IsSnapToTickEnabled="True" TickFrequency="5"
                                    AutomationProperties.Name="Upcoming section opacity"/>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Completed section opacity:" Width="200" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CompletedSectionOpacity}" Width="36" VerticalAlignment="Center" Foreground="#0078D4" FontWeight="Bold"/>
                                <TextBlock Text="%" VerticalAlignment="Center"/>
                            </StackPanel>
                            <Slider Minimum="0" Maximum="100" Value="{Binding CompletedSectionOpacity}"
                                    Width="380" HorizontalAlignment="Left" Margin="0,2,0,0"
                                    IsSnapToTickEnabled="True" TickFrequency="5"
                                    AutomationProperties.Name="Completed section opacity"/>
                        </StackPanel>

                        <Separator Margin="0,8,0,10"/>

                        <!-- Visibility flags -->
                        <TextBlock Text="Show / Hide Elements" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Show section labels"         IsChecked="{Binding ShowSectionLabels}"       Margin="0,0,0,5"/>
                        <CheckBox Content="Show session title"          IsChecked="{Binding ShowSessionTitle}"        Margin="0,0,0,5"/>
                        <CheckBox Content="Show current section title"  IsChecked="{Binding ShowCurrentSectionTitle}" Margin="0,0,0,5"/>
                        <CheckBox Content="Show next section title"     IsChecked="{Binding ShowNextSectionTitle}"    Margin="0,0,0,5"/>
                        <CheckBox Content="Show time remaining"         IsChecked="{Binding ShowTimeRemaining}"       Margin="0,0,0,5"/>
                        <CheckBox Content="Show elapsed time"           IsChecked="{Binding ShowElapsedTime}"         Margin="0,0,0,5"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── OVERLAY LAYOUT ───────────────────────────────────────────── -->
            <TabItem Header="Overlay Layout">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,12">

                        <TextBlock Text="Mode &amp; Position" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Overlay mode:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="0" Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.OverlayModeOptions}}"
                                      SelectedItem="{Binding OverlayMode}" MaxWidth="220" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Position:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="2" Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.PositionOptions}}"
                                      SelectedItem="{Binding Position}" MaxWidth="220" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Monitor:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="4" Grid.Column="1"
                                      ItemsSource="{Binding AvailableMonitors}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="DeviceName"
                                      SelectedValue="{Binding SelectedMonitorDeviceName, UpdateSourceTrigger=PropertyChanged}"
                                      MaxWidth="280" HorizontalAlignment="Left"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Height:" VerticalAlignment="Center"/>
                            <ComboBox Grid.Row="6" Grid.Column="1"
                                      ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.HeightOptions}}"
                                      SelectedItem="{Binding OverlayHeight}" MaxWidth="220" HorizontalAlignment="Left"/>
                        </Grid>

                        <Separator Margin="0,8,0,10"/>

                        <!-- Width fraction slider -->
                        <TextBlock Text="Width" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <StackPanel Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Width (fraction of monitor):" Width="200" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding WidthFraction, StringFormat='{}{0:P0}'}"
                                           Width="44" VerticalAlignment="Center" Foreground="#0078D4" FontWeight="Bold"/>
                            </StackPanel>
                            <Slider Minimum="0.2" Maximum="1.0" Value="{Binding WidthFraction}"
                                    Width="380" HorizontalAlignment="Left" Margin="0,2,0,0"
                                    IsSnapToTickEnabled="True" TickFrequency="0.05"
                                    AutomationProperties.Name="Overlay width fraction"
                                    AutomationProperties.HelpText="Set overlay width as a fraction of the monitor width"/>
                        </StackPanel>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Position Options" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Remember custom position when dragged"
                                  IsChecked="{Binding RememberCustomPosition}" Margin="0,0,0,6"/>
                        <CheckBox Content="Enable drag to move overlay"
                                  IsChecked="{Binding EnableDragToMove}" Margin="0,0,0,6"/>
                        <CheckBox Content="Snap to screen edges when dragging"
                                  IsChecked="{Binding SnapToScreenEdges}" Margin="0,0,0,6"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── ALERTS ───────────────────────────────────────────────────── -->
            <TabItem Header="Alerts">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,12">

                        <!-- Section warning -->
                        <TextBlock Text="Section Warning" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Enable section warning alerts"
                                  IsChecked="{Binding EnableSectionWarningAlerts}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Warning threshold (hh:mm:ss):" VerticalAlignment="Center" Width="220"/>
                            <TextBox Text="{Binding SectionWarningThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Width="90"/>
                        </StackPanel>

                        <Separator Margin="0,4,0,10"/>

                        <!-- Session warning -->
                        <TextBlock Text="Session Warning" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Enable session warning alerts"
                                  IsChecked="{Binding EnableSessionWarningAlerts}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="Warning threshold (hh:mm:ss):" VerticalAlignment="Center" Width="220"/>
                            <TextBox Text="{Binding SessionWarningThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     Width="90"/>
                        </StackPanel>

                        <Separator Margin="0,4,0,10"/>

                        <!-- Other alert flags -->
                        <TextBlock Text="Alert Events" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Enable section end alerts"       IsChecked="{Binding EnableSectionEndAlerts}"   Margin="0,0,0,5"/>
                        <CheckBox Content="Enable session end alerts"       IsChecked="{Binding EnableSessionEndAlerts}"   Margin="0,0,0,5"/>
                        <CheckBox Content="Enable overtime alerts"          IsChecked="{Binding EnableOvertimeAlerts}"     Margin="0,0,0,5"/>
                        <CheckBox Content="Enable overlay pulse animation"  IsChecked="{Binding EnableOverlayPulse}"       Margin="0,0,0,5"/>

                        <Separator Margin="0,8,0,10"/>

                        <!-- Notification channels -->
                        <TextBlock Text="Notification Channels" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Enable sound alerts (default: off)"
                                  IsChecked="{Binding EnableSoundAlerts}" Margin="0,0,0,6"/>
                        <CheckBox Content="Enable Windows notifications (default: off)"
                                  IsChecked="{Binding EnableWindowsNotifications}" Margin="0,0,0,6"/>

                        <Separator Margin="0,8,0,10"/>

                        <!-- Alert message duration -->
                        <TextBlock Text="Alert Message Duration" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Display duration (seconds):" VerticalAlignment="Center" Width="200"/>
                            <TextBox Text="{Binding AlertMessageDurationSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     Width="60"/>
                        </StackPanel>

                        <Separator Margin="0,10,0,10"/>

                        <!-- Test sound -->
                        <TextBlock Text="Audio Test" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="🔊 Test Sound"
                                    Command="{Binding TestSoundCommand}"
                                    Padding="10,5"
                                    AutomationProperties.Name="Test alert sound"
                                    ToolTip="Play the test sound immediately (always audible, ignores the Enable Sound Alerts toggle)."/>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── HOTKEYS ──────────────────────────────────────────────────── -->
            <TabItem Header="Hotkeys">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,12">

                        <CheckBox Content="Enable global hotkeys"
                                  IsChecked="{Binding HotkeysEnabled}"
                                  FontWeight="SemiBold"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="All hotkeys are disabled by default to avoid conflicts with other apps."
                                   TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,14"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Pause / Resume:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding PauseResumeHotkey, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HotkeysEnabled}"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Next Section:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding NextSectionHotkey, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HotkeysEnabled}"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Previous Section:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Text="{Binding PreviousSectionHotkey, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HotkeysEnabled}"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Reset Session:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="6" Grid.Column="1"
                                     Text="{Binding ResetSessionHotkey, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HotkeysEnabled}"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Show / Hide Overlay:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="8" Grid.Column="1"
                                     Text="{Binding ShowHideOverlayHotkey, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HotkeysEnabled}"/>

                            <TextBlock Grid.Row="10" Grid.Column="0" Text="Extend Section +1 min:" VerticalAlignment="Center"/>
                            <TextBox Grid.Row="10" Grid.Column="1"
                                     Text="{Binding ExtendSectionOneMinuteHotkey, UpdateSourceTrigger=PropertyChanged}"
                                     IsEnabled="{Binding HotkeysEnabled}"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── ADVANCED ─────────────────────────────────────────────────── -->
            <TabItem Header="Advanced">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16,12,16,12">

                        <TextBlock Text="These settings are carried over from other tabs for quick reference."
                                   TextWrapping="Wrap" Foreground="Gray" FontSize="11" Margin="0,0,0,14"/>

                        <TextBlock Text="Overlay Click-Through" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Enable overlay click-through (mouse events pass to apps behind the overlay)"
                                  IsChecked="{Binding EnableOverlayClickThrough}"
                                  Margin="0,0,0,6"/>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Timing Edge Cases" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Pause timer when computer locks (e.g. Win+L)"
                                  IsChecked="{Binding PauseTimerWhenComputerLocks}" Margin="0,0,0,6"/>
                        <CheckBox Content="Keep counting overtime after section end"
                                  IsChecked="{Binding KeepCountingOvertimeAfterSectionEnd}" Margin="0,0,0,6"/>
                        <CheckBox Content="Keep counting overtime after session end"
                                  IsChecked="{Binding KeepCountingOvertimeAfterSessionEnd}" Margin="0,0,0,6"/>

                        <Separator Margin="0,10,0,10"/>

                        <TextBlock Text="Position Memory" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8"/>
                        <CheckBox Content="Remember custom overlay position across sessions"
                                  IsChecked="{Binding RememberCustomPosition}" Margin="0,0,0,6"/>
                        <CheckBox Content="Snap overlay to screen edges when dragging"
                                  IsChecked="{Binding SnapToScreenEdges}" Margin="0,0,0,6"/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

        <!-- ── Action Buttons Row ────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                BorderBrush="#DDDDDD" BorderThickness="0,1,0,0"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Left: file operation buttons -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <!-- Right: main action buttons -->
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left cluster -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="Open Settings Folder"
                            Command="{Binding OpenSettingsFolderCommand}"
                            Padding="10,5" Margin="0,0,6,0"/>
                    <Button Content="Export Settings…"
                            Command="{Binding ExportSettingsCommand}"
                            Padding="10,5" Margin="0,0,6,0"/>
                    <Button Content="Import Settings…"
                            Command="{Binding ImportSettingsCommand}"
                            Padding="10,5" Margin="0,0,6,0"/>
                    <Button Content="Reset to Defaults"
                            Command="{Binding ResetToDefaultsCommand}"
                            Padding="10,5"/>
                </StackPanel>

                <!-- Right cluster -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Apply"
                            Command="{Binding ApplyCommand}"
                            Padding="14,5" Margin="0,0,6,0"/>
                    <Button Content="Cancel"
                            Command="{Binding CancelCommand}"
                            IsCancel="True"
                            Padding="14,5" Margin="0,0,6,0"
                            AutomationProperties.Name="Cancel and discard changes"/>
                    <Button Content="Save"
                            Command="{Binding SaveCommand}"
                            Padding="20,5"
                            Background="#0078D4" Foreground="White"
                            FontWeight="SemiBold"
                            IsDefault="True"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
