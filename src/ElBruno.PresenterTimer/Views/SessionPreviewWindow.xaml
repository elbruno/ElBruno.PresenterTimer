<Window x:Class="ElBruno.PresenterTimer.Views.SessionPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Session Preview"
        Width="680" Height="540"
        MinWidth="520" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="True">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- Session title + description + meta pills -->
            <RowDefinition Height="Auto"/>
            <!-- Section list (stretches) -->
            <RowDefinition Height="*"/>
            <!-- Validation summary badge -->
            <RowDefinition Height="Auto"/>
            <!-- Action buttons -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ───────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">

            <TextBlock Text="{Binding Title}"
                       FontSize="18" FontWeight="Bold"
                       TextTrimming="CharacterEllipsis"
                       AutomationProperties.Name="{Binding Title, StringFormat='Session: {0}'}"/>

            <TextBlock Text="{Binding Description}"
                       FontSize="12" Foreground="Gray"
                       TextWrapping="Wrap" Margin="0,3,0,0"/>

            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                <TextBlock Text="Total Duration: " FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalDurationDisplay}"
                           Foreground="#0078D4" FontWeight="Bold"
                           FontSize="14" VerticalAlignment="Center" Margin="2,0,20,0"/>
                <TextBlock Text="Sections: " FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SectionCount}"
                           Foreground="#0078D4" FontWeight="Bold"
                           FontSize="14" VerticalAlignment="Center" Margin="2,0,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- ── Section list ─────────────────────────────────────────────── -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Sections}"
                  Margin="0,0,0,10"
                  SelectionMode="Single"
                  AutomationProperties.Name="Session sections list">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="#"        Width="36"  DisplayMemberBinding="{Binding Index}"/>
                    <GridViewColumn Header="Section"  Width="190" DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="Duration" Width="80"  DisplayMemberBinding="{Binding DurationDisplay}"/>
                    <GridViewColumn Header="Notes"    Width="310" DisplayMemberBinding="{Binding Notes}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Validation summary ────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Margin="0,0,0,14"
                Padding="10,6"
                CornerRadius="4"
                BorderThickness="1"
                AutomationProperties.Name="{Binding ValidationSummary}"
                AutomationProperties.LiveSetting="Polite">
            <Border.Style>
                <Style TargetType="Border">
                    <!-- Default = success green -->
                    <Setter Property="Background"   Value="#DFF0D8"/>
                    <Setter Property="BorderBrush"  Value="#3C763D"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasValidationIssues}" Value="True">
                            <Setter Property="Background"  Value="#FCF8E3"/>
                            <Setter Property="BorderBrush" Value="#8A6D3B"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ValidationSummary}"
                       TextWrapping="Wrap"
                       FontSize="12">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="#3C763D"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasValidationIssues}" Value="True">
                                <Setter Property="Foreground" Value="#8A6D3B"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- ── Action buttons ───────────────────────────────────────────── -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="Export Normalized JSON"
                    Command="{Binding ExportNormalizedJsonCommand}"
                    Margin="0,0,8,0" Padding="10,6"/>

            <Button Content="Import Different JSON"
                    Command="{Binding ImportDifferentJsonCommand}"
                    Margin="0,0,8,0" Padding="10,6"/>

            <Button Content="Cancel"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    Margin="0,0,8,0" Padding="10,6"
                    AutomationProperties.Name="Cancel and close preview"/>

            <Button Content="▶  Start Session"
                    Command="{Binding StartSessionCommand}"
                    Padding="12,6"
                    FontWeight="Bold"
                    Background="#0078D4"
                    Foreground="White"
                    AutomationProperties.Name="Start session"/>
        </StackPanel>
    </Grid>
</Window>
